generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client_v4"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Customer {
  id         String           @id @default(cuid())
  code       String           @unique
  name       String
  nameAr     String?
  email      String?
  phone      String?
  address    String?
  balance    Float            @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  invoices   SalesInvoice[]
  quotations SalesQuotation[]
}

model Supplier {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  nameAr    String?
  email     String?
  phone     String?
  address   String?
  balance   Float             @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  invoices  PurchaseInvoice[]
}

model Warehouse {
  id            String            @id @default(cuid())
  code          String            @unique
  name          String
  nameAr        String?
  location      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  inventoryLogs InventoryLog[]
  purchases     PurchaseInvoice[]
  invoices      SalesInvoice[]
  quotations    SalesQuotation[]
  transfersTo   StockTransfer[]   @relation("ToWarehouse")
  transfersFrom StockTransfer[]   @relation("FromWarehouse")
  stockItems    WarehouseStock[]
}

model WarehouseStock {
  id          String    @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Float     @default(0)
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, productId])
}

model Product {
  id              String              @id @default(cuid())
  sku             String              @unique
  name            String
  nameAr          String?
  description     String?
  category        String?
  unit            String              @default("pc")
  costPrice       Float               @default(0)
  salePrice       Float               @default(0)
  stockQuantity   Float               @default(0)
  reorderPoint    Float               @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  inventoryLogs   InventoryLog[]
  items           InvoiceItem[]
  purchaseItems   PurchaseItem[]
  transfers       StockTransferItem[]
  warehouseStocks WarehouseStock[]
  quotationItems  QuotationItem[]
}

model SalesInvoice {
  id               String          @id @default(cuid())
  invoiceNumber    String          @unique
  date             DateTime
  customerId       String
  warehouseId      String?
  totalAmount      Float
  taxAmount        Float           @default(0)
  discount         Float           @default(0)
  netAmount        Float
  status           String
  journalVoucherId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            InvoiceItem[]
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id])
  warehouse        Warehouse?      @relation(fields: [warehouseId], references: [id])
  customer         Customer        @relation(fields: [customerId], references: [id])
  quotation        SalesQuotation? @relation("QuotationToInvoice")
}

model PurchaseInvoice {
  id               String          @id @default(cuid())
  invoiceNumber    String          @unique
  date             DateTime
  supplierId       String
  warehouseId      String?
  totalAmount      Float
  taxAmount        Float           @default(0)
  discount         Float           @default(0)
  netAmount        Float
  status           String
  journalVoucherId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id])
  warehouse        Warehouse?      @relation(fields: [warehouseId], references: [id])
  supplier         Supplier        @relation(fields: [supplierId], references: [id])
  items            PurchaseItem[]
}

model InvoiceItem {
  id        String       @id @default(cuid())
  invoiceId String
  productId String
  quantity  Float
  unitPrice Float
  total     Float
  product   Product      @relation(fields: [productId], references: [id])
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PurchaseItem {
  id        String          @id @default(cuid())
  invoiceId String
  productId String
  quantity  Float
  unitPrice Float
  total     Float
  product   Product         @relation(fields: [productId], references: [id])
  invoice   PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model StockTransfer {
  id              String              @id @default(cuid())
  transferNumber  String              @unique
  date            DateTime            @default(now())
  fromWarehouseId String
  toWarehouseId   String
  status          String              @default("Completed")
  notes           String?
  createdAt       DateTime            @default(now())
  toWarehouse     Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  fromWarehouse   Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  items           StockTransferItem[]
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Float
  product    Product       @relation(fields: [productId], references: [id])
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

model InventoryLog {
  id          String     @id @default(cuid())
  productId   String
  warehouseId String?
  date        DateTime   @default(now())
  type        String
  quantity    Float
  referenceId String?
  description String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  product     Product    @relation(fields: [productId], references: [id])
}

model Account {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  nameAr          String?
  type            String
  parentId        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  parent          Account?             @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]            @relation("AccountHierarchy")
  entries         JournalEntry[]
  relatedVouchers TransactionVoucher[] @relation("RelatedAccount")
  primaryVouchers TransactionVoucher[] @relation("PrimaryAccount")
}

model JournalVoucher {
  id                 String              @id @default(cuid())
  reference          String              @unique
  date               DateTime
  description        String
  status             String              @default("Draft")
  createdAt          DateTime            @default(now())
  entries            JournalEntry[]
  purchaseInvoices   PurchaseInvoice[]
  invoices           SalesInvoice[]
  transactionVoucher TransactionVoucher?
}

model JournalEntry {
  id               String          @id @default(cuid())
  date             DateTime
  description      String
  accountId        String
  debit            Float           @default(0)
  credit           Float           @default(0)
  reference        String?
  journalVoucherId String?
  createdAt        DateTime        @default(now())
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id], onDelete: Cascade)
  account          Account         @relation(fields: [accountId], references: [id])
}

model TransactionVoucher {
  id               String          @id @default(cuid())
  voucherNumber    String          @unique
  type             String
  date             DateTime
  amount           Float
  description      String?
  primaryAccountId String
  relatedAccountId String
  journalVoucherId String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id])
  relatedAccount   Account         @relation("RelatedAccount", fields: [relatedAccountId], references: [id])
  primaryAccount   Account         @relation("PrimaryAccount", fields: [primaryAccountId], references: [id])
}

model CompanyProfile {
  id                  String   @id @default("default")
  name                String   @default("My Company")
  nameAr              String?  @default("شركتي")
  email               String?
  phone               String?
  logo                String?
  currency            String   @default("SAR")
  taxNumber           String?
  streetName          String?
  buildingNumber      String?
  city                String?
  district            String?
  postalCode          String?
  country             String   @default("SA")
  taxSupplyDateType   String   @default("issue")
  separateTaxAccounts Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model SalesQuotation {
  id                   String          @id @default(cuid())
  quotationNumber      String          @unique
  date                 DateTime
  validUntil           DateTime?
  customerId           String
  warehouseId          String?
  totalAmount          Float
  taxAmount            Float           @default(0)
  discount             Float           @default(0)
  netAmount            Float
  status               String          @default("Draft") // Draft, Sent, Accepted, Rejected, Converted
  convertedToInvoiceId String?         @unique
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  items                QuotationItem[]
  warehouse            Warehouse?      @relation(fields: [warehouseId], references: [id])
  customer             Customer        @relation(fields: [customerId], references: [id])
  convertedTo          SalesInvoice?   @relation("QuotationToInvoice", fields: [convertedToInvoiceId], references: [id])
}

model QuotationItem {
  id          String         @id @default(cuid())
  quotationId String
  productId   String
  quantity    Float
  unitPrice   Float
  total       Float
  product     Product        @relation(fields: [productId], references: [id])
  quotation   SalesQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String?
  role      String   @default("Accountant") // Admin, Accountant, Viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
