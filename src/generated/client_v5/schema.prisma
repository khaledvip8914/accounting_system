generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client_v5"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id         String           @id @default(cuid())
  code       String           @unique
  name       String
  nameAr     String?
  email      String?
  phone      String?
  address    String?
  balance    Float            @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  invoices   SalesInvoice[]
  quotations SalesQuotation[]
}

model Supplier {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  nameAr    String?
  email     String?
  phone     String?
  address   String?
  balance   Float             @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  invoices  PurchaseInvoice[]
}

model Warehouse {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  nameAr           String?
  location         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  inventoryLogs    InventoryLog[]
  productionOrders ProductionOrder[]
  purchases        PurchaseInvoice[]
  invoices         SalesInvoice[]
  quotations       SalesQuotation[]
  transfersTo      StockTransfer[]   @relation("ToWarehouse")
  transfersFrom    StockTransfer[]   @relation("FromWarehouse")
  stockItems       WarehouseStock[]
  disposalVouchers DisposalVoucher[]
}

model WarehouseStock {
  id          String    @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Float     @default(0)
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, productId])
}

model Product {
  id               String                @id @default(cuid())
  sku              String                @unique
  name             String
  nameAr           String?
  description      String?
  category         String?
  classification   String                @default("Finished Product")
  unit             String                @default("pc")
  unitId           String?
  costPrice        Float                 @default(0)
  salePrice        Float                 @default(0)
  stockQuantity    Float                 @default(0)
  reorderPoint     Float                 @default(0)
  caloriesPer100g  Float                 @default(0)
  expiryDate       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  unitQuantity     Float                 @default(1)
  subUnitId        String?
  costCenters      CostCenter[]
  costCenterItems  CostCenterItem[]
  inventoryLogs    InventoryLog[]
  items            InvoiceItem[]
  subUnitRef       UnitOfMeasure?        @relation("SubUnit", fields: [subUnitId], references: [id])
  unitRef          UnitOfMeasure?        @relation("MainUnit", fields: [unitId], references: [id])
  productionOrders ProductionOrder[]     @relation("FinishedProduct")
  usages           ProductionOrderItem[] @relation("RawMaterialUsage")
  purchaseItems    PurchaseItem[]
  quotationItems   QuotationItem[]
  transfers        StockTransferItem[]
  warehouseStocks  WarehouseStock[]
  disposalVouchers DisposalVoucher[]
}

model SalesInvoice {
  id               String          @id @default(cuid())
  invoiceNumber    String          @unique
  date             DateTime
  customerId       String
  warehouseId      String?
  totalAmount      Float
  taxAmount        Float           @default(0)
  discount         Float           @default(0)
  netAmount        Float
  status           String
  journalVoucherId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            InvoiceItem[]
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id])
  warehouse        Warehouse?      @relation(fields: [warehouseId], references: [id])
  customer         Customer        @relation(fields: [customerId], references: [id])
  quotation        SalesQuotation? @relation("QuotationToInvoice")
}

model PurchaseInvoice {
  id               String          @id @default(cuid())
  invoiceNumber    String          @unique
  date             DateTime
  supplierId       String
  warehouseId      String?
  totalAmount      Float
  taxAmount        Float           @default(0)
  discount         Float           @default(0)
  netAmount        Float
  status           String
  journalVoucherId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id])
  warehouse        Warehouse?      @relation(fields: [warehouseId], references: [id])
  supplier         Supplier        @relation(fields: [supplierId], references: [id])
  items            PurchaseItem[]
}

model InvoiceItem {
  id        String       @id @default(cuid())
  invoiceId String
  productId String
  unitId    String?
  quantity  Float
  unitPrice Float
  total     Float
  product   Product      @relation(fields: [productId], references: [id])
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PurchaseItem {
  id        String          @id @default(cuid())
  invoiceId String
  productId String
  unitId    String?
  quantity  Float
  unitPrice Float
  total     Float
  product   Product         @relation(fields: [productId], references: [id])
  invoice   PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model StockTransfer {
  id              String              @id @default(cuid())
  transferNumber  String              @unique
  date            DateTime            @default(now())
  fromWarehouseId String
  toWarehouseId   String
  status          String              @default("Completed")
  notes           String?
  createdAt       DateTime            @default(now())
  toWarehouse     Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  fromWarehouse   Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  items           StockTransferItem[]
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Float
  product    Product       @relation(fields: [productId], references: [id])
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

model InventoryLog {
  id          String     @id @default(cuid())
  productId   String
  warehouseId String?
  unitId      String?
  unitName    String?
  date        DateTime   @default(now())
  type        String
  quantity    Float
  referenceId String?
  description String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  product     Product    @relation(fields: [productId], references: [id])
}

model Account {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  nameAr          String?
  type            String
  nature          String               @default("Debit")
  description     String?
  parentId        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  parent          Account?             @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]            @relation("AccountHierarchy")
  entries         JournalEntry[]
  primaryVouchers TransactionVoucher[] @relation("PrimaryAccount")
  relatedVouchers TransactionVoucher[] @relation("RelatedAccount")
}

model JournalVoucher {
  id                 String              @id @default(cuid())
  reference          String              @unique
  date               DateTime
  description        String
  status             String              @default("Draft")
  createdAt          DateTime            @default(now())
  entries            JournalEntry[]
  purchaseInvoices   PurchaseInvoice[]
  invoices           SalesInvoice[]
  transactionVoucher TransactionVoucher?
  salaryPayments     SalaryPayment[]
}

model JournalEntry {
  id               String          @id @default(cuid())
  date             DateTime
  description      String
  accountId        String
  debit            Float           @default(0)
  credit           Float           @default(0)
  reference        String?
  journalVoucherId String?
  createdAt        DateTime        @default(now())
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id], onDelete: Cascade)
  account          Account         @relation(fields: [accountId], references: [id])
}

model TransactionVoucher {
  id               String          @id @default(cuid())
  voucherNumber    String          @unique
  type             String
  date             DateTime
  amount           Float
  description      String?
  primaryAccountId String
  relatedAccountId String
  journalVoucherId String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  primaryAccount   Account         @relation("PrimaryAccount", fields: [primaryAccountId], references: [id])
  relatedAccount   Account         @relation("RelatedAccount", fields: [relatedAccountId], references: [id])
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id])
}

model CompanyProfile {
  id                  String   @id @default("default")
  name                String   @default("My Company")
  nameAr              String?  @default("شركتي")
  email               String?
  phone               String?
  logo                String?
  currency            String   @default("SAR")
  taxNumber           String?
  streetName          String?
  buildingNumber      String?
  city                String?
  district            String?
  postalCode          String?
  country             String   @default("SA")
  taxSupplyDateType   String   @default("issue")
  separateTaxAccounts Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model SalesQuotation {
  id                   String          @id @default(cuid())
  quotationNumber      String          @unique
  date                 DateTime
  validUntil           DateTime?
  customerId           String
  warehouseId          String?
  totalAmount          Float
  taxAmount            Float           @default(0)
  discount             Float           @default(0)
  netAmount            Float
  status               String          @default("Draft")
  convertedToInvoiceId String?         @unique
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  items                QuotationItem[]
  convertedTo          SalesInvoice?   @relation("QuotationToInvoice", fields: [convertedToInvoiceId], references: [id])
  customer             Customer        @relation(fields: [customerId], references: [id])
  warehouse            Warehouse?      @relation(fields: [warehouseId], references: [id])
}

model QuotationItem {
  id          String         @id @default(cuid())
  quotationId String
  productId   String
  quantity    Float
  unitPrice   Float
  total       Float
  quotation   SalesQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product        @relation(fields: [productId], references: [id])
}

model UnitOfMeasure {
  id               String                @id @default(cuid())
  name             String                @unique
  nameAr           String?
  parentUnitId     String?
  conversionFactor Float?                @default(1)
  ccItems          CostCenterItem[]      @relation("CCItemUnit")
  subProducts      Product[]             @relation("SubUnit")
  mainProducts     Product[]             @relation("MainUnit")
  poItems          ProductionOrderItem[] @relation("POItemUnit")
  parentUnit       UnitOfMeasure?        @relation("UnitConversions", fields: [parentUnitId], references: [id])
  childUnits       UnitOfMeasure[]       @relation("UnitConversions")
}

model CostCenter {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  nameAr       String?
  description  String?
  productId    String?
  quantityUsed Float            @default(0)
  yieldWeight  Float            @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  product      Product?         @relation(fields: [productId], references: [id])
  items        CostCenterItem[]
}

model CostCenterItem {
  id           String         @id @default(cuid())
  costCenterId String
  productId    String
  unitId       String?
  quantity     Float          @default(0)
  costPrice    Float          @default(0)
  ratio        Float          @default(0)
  product      Product        @relation(fields: [productId], references: [id])
  unit         UnitOfMeasure? @relation("CCItemUnit", fields: [unitId], references: [id])
  costCenter   CostCenter     @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
}

model ProductionOrder {
  id          String                @id @default(cuid())
  orderNumber String                @unique
  date        DateTime              @default(now())
  productId   String
  quantity    Float                 @default(0)
  warehouseId String
  status      String                @default("Draft")
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  warehouse   Warehouse             @relation(fields: [warehouseId], references: [id])
  product     Product               @relation("FinishedProduct", fields: [productId], references: [id])
  items       ProductionOrderItem[]
}

model ProductionOrderItem {
  id                String          @id @default(cuid())
  productionOrderId String
  productId         String
  unitId            String?
  quantity          Float
  ratio             Float           @default(0)
  costPrice         Float           @default(0)
  product           Product         @relation("RawMaterialUsage", fields: [productId], references: [id])
  unit              UnitOfMeasure?  @relation("POItemUnit", fields: [unitId], references: [id])
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String?  @unique
  password    String
  name        String?
  role        String   @default("Employee")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  permissions String?
}

model Employee {
  id             String                  @id @default(cuid())
  code           String                  @unique
  name           String
  nameAr         String?
  jobTitle       String?
  jobTitleAr     String?
  department     String?
  basicSalary    Float                   @default(0)
  idNumber       String?
  idExpiry       DateTime?
  joinDate       DateTime                @default(now())
  status         String                  @default("Active")
  phone          String?
  email          String?
  address        String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  financialMoves EmployeeFinancialMove[]
  salaryPayments SalaryPayment[]
}

model EmployeeFinancialMove {
  id         String   @id @default(cuid())
  employeeId String
  type       String // Advance, Penalty, Reward, Allowance
  amount     Float
  date       DateTime @default(now())
  reason     String?
  status     String   @default("Confirmed")
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SalaryPayment {
  id               String          @id @default(cuid())
  employeeId       String
  month            Int
  year             Int
  basicSalary      Float
  allowances       Float           @default(0)
  rewards          Float           @default(0)
  advances         Float           @default(0)
  penalties        Float           @default(0)
  netSalary        Float
  status           String          @default("Pending") // Pending, Approved
  journalVoucherId String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  employee         Employee        @relation(fields: [employeeId], references: [id])
  journalVoucher   JournalVoucher? @relation(fields: [journalVoucherId], references: [id])

  @@unique([employeeId, month, year])
}

model DisposalVoucher {
  id            String    @id @default(cuid())
  voucherNumber String    @unique
  date          DateTime  @default(now())
  productId     String
  warehouseId   String
  unitId        String?
  quantity      Float
  reason        String
  notes         String?
  status        String    @default("Confirmed")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  product       Product   @relation(fields: [productId], references: [id])
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
}
